<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:conv="clr-namespace:Ubad.Converters">

    <!-- ── Brand Colors ─────────────────────────────────────── -->
    <Color x:Key="Primary">#6C63FF</Color>
    <Color x:Key="PrimaryDark">#5A52E0</Color>
    <Color x:Key="PrimaryLight">#8B85FF</Color>
    <Color x:Key="Secondary">#FF6584</Color>
    <Color x:Key="Accent">#43E97B</Color>
    <Color x:Key="AccentBlue">#38F9D7</Color>
    <Color x:Key="Warning">#FFB547</Color>
    <Color x:Key="Error">#FF5252</Color>
    <Color x:Key="Success">#43E97B</Color>

    <!-- ── Gradients ─────────────────────────────────────────── -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6C63FF" Offset="0.0"/>
        <GradientStop Color="#5A52E0" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6C63FF" Offset="0.0"/>
        <GradientStop Color="#FF6584" Offset="0.6"/>
        <GradientStop Color="#43E97B" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#00FFFFFF" Offset="0.0"/>
        <GradientStop Color="#15FFFFFF" Offset="1.0"/>
    </LinearGradientBrush>

    <!-- ── Converters ────────────────────────────────────────── -->
    <conv:BoolToVisibilityConverter    x:Key="BoolToVisibility"/>
    <conv:InverseBoolConverter         x:Key="InverseBool"/>
    <conv:NullToVisibilityConverter    x:Key="NullToVisibility"/>
    <conv:HexToColorConverter          x:Key="HexToColor"/>
    <conv:StarCountConverter           x:Key="StarCount"/>
    <conv:EmptyListToVisibilityConverter x:Key="EmptyListToVisibility"/>
    <conv:IntToVisibilityConverter     x:Key="IntToVisibility"/>

    <!-- ── Typography ────────────────────────────────────────── -->
    <Style x:Key="HeadlineStyle" TargetType="Label">
        <Setter Property="FontFamily"   Value="InterBold"/>
        <Setter Property="FontSize"     Value="28"/>
        <Setter Property="TextColor"    Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"/>
        <Setter Property="LineHeight"   Value="1.2"/>
    </Style>

    <Style x:Key="TitleStyle" TargetType="Label">
        <Setter Property="FontFamily"   Value="InterSemiBold"/>
        <Setter Property="FontSize"     Value="20"/>
        <Setter Property="TextColor"    Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"/>
    </Style>

    <Style x:Key="SubtitleStyle" TargetType="Label">
        <Setter Property="FontFamily"   Value="InterMedium"/>
        <Setter Property="FontSize"     Value="16"/>
        <Setter Property="TextColor"    Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"/>
    </Style>

    <Style x:Key="BodyStyle" TargetType="Label">
        <Setter Property="FontFamily"   Value="InterRegular"/>
        <Setter Property="FontSize"     Value="14"/>
        <Setter Property="TextColor"    Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"/>
        <Setter Property="LineHeight"   Value="1.5"/>
    </Style>

    <Style x:Key="CaptionStyle" TargetType="Label">
        <Setter Property="FontFamily"   Value="InterRegular"/>
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="TextColor"    Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"/>
    </Style>

    <Style x:Key="BadgeLabelStyle" TargetType="Label">
        <Setter Property="FontFamily"   Value="InterSemiBold"/>
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="TextColor"    Value="White"/>
    </Style>

    <!-- ── Buttons ────────────────────────────────────────────── -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor"      Value="{StaticResource Primary}"/>
        <Setter Property="TextColor"            Value="White"/>
        <Setter Property="FontFamily"           Value="InterSemiBold"/>
        <Setter Property="FontSize"             Value="15"/>
        <Setter Property="CornerRadius"         Value="12"/>
        <Setter Property="HeightRequest"        Value="48"/>
        <Setter Property="Padding"              Value="20,0"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="12" Opacity="0.35"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor"  Value="Transparent"/>
        <Setter Property="TextColor"        Value="{StaticResource Primary}"/>
        <Setter Property="FontFamily"       Value="InterSemiBold"/>
        <Setter Property="FontSize"         Value="15"/>
        <Setter Property="CornerRadius"     Value="12"/>
        <Setter Property="HeightRequest"    Value="48"/>
        <Setter Property="Padding"          Value="20,0"/>
        <Setter Property="BorderColor"      Value="{StaticResource Primary}"/>
        <Setter Property="BorderWidth"      Value="1.5"/>
    </Style>

    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor"  Value="Transparent"/>
        <Setter Property="TextColor"        Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"/>
        <Setter Property="FontFamily"       Value="InterMedium"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="CornerRadius"     Value="8"/>
        <Setter Property="HeightRequest"    Value="40"/>
    </Style>

    <!-- ── Cards ─────────────────────────────────────────────── -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"/>
        <Setter Property="StrokeShape"  Value="RoundRectangle 16"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="Stroke"
                Value="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="Black" Offset="0,4" Radius="16" Opacity="0.08"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Search Bar ─────────────────────────────────────────── -->
    <Style x:Key="SearchBarStyle" TargetType="SearchBar">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"/>
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"/>
        <Setter Property="PlaceholderColor"
                Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"/>
        <Setter Property="FontFamily" Value="InterRegular"/>
        <Setter Property="FontSize"   Value="14"/>
    </Style>

    <!-- ── Page ──────────────────────────────────────────────── -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"/>
    </Style>

    <!-- ── Separator ─────────────────────────────────────────── -->
    <Style x:Key="DividerStyle" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="Color"
                Value="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}"/>
    </Style>

    <!-- ── Skeleton ──────────────────────────────────────────── -->
    <Style x:Key="SkeletonStyle" TargetType="BoxView">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource SkeletonLight}, Dark={StaticResource SkeletonDark}}"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

</ResourceDictionary>